            "method": "POST",
            "auth": null,
            "body": {
              "mode": "raw",
              "raw": "{\n  \"policy\": \"<string>\",\n  \"retainCommits\": \"<integer>\",\n  \"retainFileVersions\": \"<integer>\",\n  \"triggerStrategy\": \"<string>\"\n}",
              "options": {
