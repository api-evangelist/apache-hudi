                      "disabled": false,
                      "type": "any",
                      "value": "<string>",
                      "key": "tableName",
                      "description": "(Required) "
                    }
                  ]
                },
                "method": "POST",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"policy\": \"KEEP_LATEST_COMMITS\",\n  \"retainCommits\": 10,\n  \"retainFileVersions\": 3,\n  \"triggerStrategy\": \"NUM_COMMITS\"\n}",
