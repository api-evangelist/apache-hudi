          "name": "Apache Hudi Run Cleaning",
          "request": {
            "name": "Apache Hudi Run Cleaning",
            "description": {
              "content": "Trigger a cleaning operation on a Hudi table to remove old file versions.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "v1",
                "hoodie",
                "table",
                ":tableName",
                "clean"
